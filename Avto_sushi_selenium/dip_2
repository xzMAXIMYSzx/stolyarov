@allure.step("Ввод адреса доставки: {address}")
def enter_delivery_address(driver, address):
    """Находит поле адреса и вводит текст"""
    try:
        # Список возможных селекторов для поля адреса
        selectors = [
            (By.ID, "r_6", "по ID r_6"),
            (By.XPATH, "//input[@placeholder='Введите адрес']", "по плейсхолдеру"),
            (By.XPATH, "//input[contains(@class, 'sc-d355a125-5')]", "по классу sc-d355a125-5"),
            (By.XPATH, "//div[contains(@class, 'sc-d355a125-4')]//input", "по контейнеру"),
            (By.XPATH, "//input[@type='text' and contains(@placeholder, 'адрес')]", "комбинированный")
        ]

        address_input = None
        selected_desc = ""

        for by, selector, desc in selectors:
            try:
                address_input = WebDriverWait(driver, 3).until(
                    EC.element_to_be_clickable((by, selector))
                )
                selected_desc = desc
                logger.info(f"✅✅✅ СРАБОТАЛО: {desc} — {by} = {selector}")
                break
            except:
                logger.debug(f"❌ Не сработало: {desc}")
                continue

        if not address_input:
            raise Exception("Поле адреса не найдено ни по одному селектору")

        # Прокрутка и наведение
        driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", address_input)
        time.sleep(1)
        ActionChains(driver).move_to_element(address_input).perform()
        time.sleep(1)

        # Ввод адреса
        address_input.click()
        address_input.clear()
        address_input.send_keys(address)
        logger.info(f"✅ Адрес '{address}' введён")

        time.sleep(2)

        # Жмём Enter или выбираем первую подсказку
        address_input.send_keys(u'\ue007')
        logger.info("✅ Адрес подтверждён")
        allure.attach(
            f"Сработал селектор: {selected_desc}",
            name="Результат поиска поля адреса",
            attachment_type=allure.attachment_type.TEXT
        )
        attach_screenshot(driver, "Адрес_введен")
        return True
    except Exception as e:
        logger.error(f"❌ Ошибка при вводе адреса: {e}")
        attach_screenshot(driver, "Ошибка_ввода_адреса")
        raise


