@allure.step("Поиск товара по названию: {query}")
def search_product(driver, query):
    """Активирует поиск, кликает по иконке и вводит текст"""
    try:
        logger.info("🔍 Активация поиска...")
        search_trigger = WebDriverWait(driver, 10).until(
            EC.element_to_be_clickable((By.XPATH, "//div[contains(@class, 'sc-7d19f7fd-0')]"))
        )
        search_trigger.click()
        logger.info("✅ Иконка поиска нажата")
        time.sleep(1)

        search_input = WebDriverWait(driver, 10).until(
            EC.visibility_of_element_located((By.XPATH, "//input[@placeholder='Чем хочешь перекусить?']"))
        )
        search_input.click()
        search_input.clear()
        search_input.send_keys(query)
        logger.info(f"✅ Введен текст: {query}")
        search_input.send_keys(u'\ue007')
        logger.info("✅ Поиск выполнен")

        # Даём время на загрузку результатов
        time.sleep(3)
        attach_screenshot(driver, "Результаты_поиска")

        # Пробуем найти элемент разными способами
        domino = None
        xpath_options = [
            "//*[contains(text(), 'ролл Домино')]",
            "//a[contains(@href, 'domino')]",
            "//div[contains(@class, 'product')]//*[contains(text(), 'Домино')]"
        ]

        for xpath in xpath_options:
            try:
                domino = WebDriverWait(driver, 3).until(
                    EC.element_to_be_clickable((By.XPATH, xpath))
                )
                logger.info(f"✅ Элемент найден по: {xpath}")
                break
            except:
                continue

        if not domino:
            raise Exception("Элемент 'ролл Домино' не найден ни по одному XPath")

        driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", domino)
        time.sleep(1)

        try:
            domino.click()
        except ElementClickInterceptedException:
            driver.execute_script("arguments[0].click();", domino)
            logger.info("✅ Клик через JavaScript")

        time.sleep(2)
        attach_screenshot(driver, "Страница_товара")
        return True

    except Exception as e:
        logger.error(f"❌ Ошибка поиска: {str(e)}")
        attach_screenshot(driver, "Ошибка_поиска")
        raise


