pipeline {
    agent any
    
    environment {
        PYTHONIOENCODING = 'utf-8'
        PYTHONUTF8 = '1'
        // Укажи правильный путь к Python на Jenkins-машине
        PYTHON_PATH = 'C:\\Python311\\python.exe'
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📥 Клонирование репозитория...'
                checkout scm
            }
        }
        
        stage('Setup Dependencies') {
            steps {
                echo '🔧 Установка зависимостей...'
                bat """
                    chcp 65001
                    ${PYTHON_PATH} -m pip install --upgrade pip
                    ${PYTHON_PATH} -m pip install -r Avto_sushi_selenium/requirements.txt
                """
            }
        }
        
        stage('Run Tests') {
            steps {
                echo '🚀 Запуск тестов...'
                bat """
                    chcp 65001
                    cd Avto_sushi_selenium
                    ${PYTHON_PATH} -m pytest dip_3.py -v --alluredir=../allure-results --junitxml=../test-results.xml
                """
            }
            post {
                always {
                    junit 'test-results.xml'
                }
            }
        }
        
        stage('Allure Report') {
            steps {
                echo '📊 Генерация Allure отчета...'
                allure includeProperties: false,
                      jdk: '',
                      results: [[path: 'allure-results']]
            }
        }
    }
    
    post {
        always {
            echo '🏁 Сборка завершена'
        }
        success {
            echo '✅ Все тесты прошли успешно!'
        }
        failure {
            echo '❌ Тесты упали! Проверьте отчет Allure'
        }
    }
}
