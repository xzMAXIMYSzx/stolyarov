pipeline {
    agent any
    
    environment {
        PYTHONIOENCODING = 'utf-8'
        PYTHONUTF8 = '1'
        PYTHON_PATH = 'python'  // проверь путь!
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📥 Клонирование репозитория...'
                checkout scm
            }
        }
        
        stage('Setup Dependencies') {
    steps {
        echo '🔧 Установка зависимостей...'
        bat '''
            chcp 65001
            set PATH=C:\\python;%PATH%
            cd Avto_sushi_selenium
            python -m pip install --upgrade pip
            python -m pip install -r requirements.txt
        '''
    }
}
        
        stage('Run Tests') {
            steps {
                echo '🚀 Запуск тестов...'
                bat """
                    chcp 65001
                    cd Avto_sushi_selenium
                    ${PYTHON_PATH} -m pytest dip_3.py -v --alluredir=../allure-results --junitxml=../test-results.xml
                """
            }
            post {
                always {
                    junit 'test-results.xml'
                }
            }
        }
        
        stage('Allure Report') {
            steps {
                echo '📊 Генерация Allure отчета...'
                allure includeProperties: false,
                      jdk: '',
                      results: [[path: 'allure-results']]
            }
        }
    }
    
    post {
        always {
            echo '🏁 Сборка завершена'
        }
        success {
            echo '✅ Все тесты прошли успешно!'
        }
        failure {
            echo '❌ Тесты упали! Проверьте отчет Allure'
        }
    }
}
